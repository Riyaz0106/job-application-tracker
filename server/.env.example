# ---------------------------------------------------------------------------
# Server environment. Copy this file to `server/.env` and fill in real values.
# `server/.env` is git-ignored and must never be committed.
# Both the running server (via src/config/env.ts) and the Prisma CLI
# (via prisma.config.ts) read this file.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma + the server at runtime.
# Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# For your LOCAL Postgres with the database you created ("job_tracker"):
#   - USER / PASSWORD: your local Postgres role + its password
#   - HOST: localhost   PORT: 5432 (the pgAdmin/Postgres default)
#   - DATABASE: job_tracker
# Example shape (NOT real credentials — replace USER and PASSWORD):
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/job_tracker?schema=public"

# Port the Express API listens on.
PORT=4000

# development | production | test
NODE_ENV=development

# Secret used to sign/verify JWTs (Phase 4). Must be long and random.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-string

# ---------------------------------------------------------------------------
# Placeholders for later phases (reference only):
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
