# ---------------------------------------------------------------------------
# CLIENT environment. Copy this file to `.env` (repo root) and fill in values.
# `.env` is git-ignored. Vite loads this file (see client/vite.config.ts
# `envDir: '..'`) and only exposes variables prefixed with VITE_.
#
# SERVER config (DATABASE_URL, PORT, NODE_ENV, secrets) now lives in a separate
# file: see server/.env.example  ->  copy to server/.env.
# ---------------------------------------------------------------------------

# Base URL the frontend uses to reach the API.
# In dev this is proxied by Vite, so it can stay relative.
VITE_API_URL=http://localhost:4000
