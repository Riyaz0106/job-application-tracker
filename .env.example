# ---------------------------------------------------------------------------
# Example environment variables. Copy this file to `.env` and fill in values.
# `.env` is git-ignored and must never be committed.
# Only placeholders live here — no real secrets.
# ---------------------------------------------------------------------------

# --- Server ---
# Port the Express API listens on.
PORT=4000

# Node environment: development | production | test
NODE_ENV=development

# --- Client ---
# Base URL the frontend uses to reach the API.
# In dev this is proxied by Vite, so it can stay relative.
VITE_API_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Placeholders for later phases (NOT used in Phase 1 — here for reference only):
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/job_tracker
# JWT_SECRET=replace-with-a-long-random-string
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
